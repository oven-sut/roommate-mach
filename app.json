{
  "expo": {
    "name": "Roommate Mach",
    "slug": "roommate-mach",
    "scheme": "roomiematch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ovensut.roommatemach"
    },
    "android": {
      "package": "com.ovensut.roommatemach",
      "adaptiveIcon": {
        "backgroundColor": "#FCF8F6",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
